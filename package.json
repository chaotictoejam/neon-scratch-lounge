{
  "name": "neon-scratch-lounge",
  "version": "1.0.0",
  "description": "The Neon Scratch Lounge — A cyberpunk cat RPG on production AWS infrastructure",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "demo:new-game-warrior": "ts-node scripts/demo.ts new TabbyWarrior",
    "demo:new-game-mage": "ts-node scripts/demo.ts new SiameseMage",
    "demo:new-game-paladin": "ts-node scripts/demo.ts new MaineCoonPaladin",
    "demo:new-game-rogue": "ts-node scripts/demo.ts new SphinxRogue",
    "demo:action": "ts-node scripts/demo.ts action",
    "demo:attack": "ts-node scripts/demo.ts action 'I slash at the Roomba drone with my HackingClaws'",
    "demo:explore": "ts-node scripts/demo.ts action 'I slip into the shadows of Chrome Alley'",
    "demo:use-item": "ts-node scripts/demo.ts action 'I crack open the Mystery Can of Tuna'",
    "demo:trigger-failure": "ts-node scripts/demo.ts failure",
    "demo:show-logs": "ts-node scripts/demo.ts logs",
    "demo:show-campaign": "ts-node scripts/demo.ts campaign",
    "demo:reset": "ts-node scripts/demo.ts reset"
  },
  "dependencies": {
    "@aws-cdk/aws-bedrock-alpha": "^2.257.0-alpha.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.600.0",
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-eventbridge": "^3.600.0",
    "@aws-sdk/client-lambda": "^3.600.0",
    "@aws-sdk/client-sfn": "^3.600.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "@types/uuid": "^9.0.0",
    "aws-cdk": "^2.257.0",
    "esbuild": "^0.28.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    }
  }
}
